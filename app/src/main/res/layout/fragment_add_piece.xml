<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    tools:context=".Data.AddPieceFragment">

    <!-- Top Header Profile Banner -->
    <View
        android:id="@+id/topHeaderAddPiece"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#5B4242"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBackAddPieceFragment"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Publish Artwork"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="@id/btnBackAddPieceFragment"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackAddPieceFragment" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHeaderAddPiece">

        <!-- الورقة البيضاء التي تجمع كل العناصر بجمالية وانحناء متناسق -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="30dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artwork Details"
                    android:textColor="#5B4242"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <EditText
                    android:id="@+id/etNameAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Artwork Name"
                    android:paddingHorizontal="15dp"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp"/>

                <Spinner
                    android:id="@+id/spCategoryAddPiece"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:paddingHorizontal="10dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etArtistAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Artist Name"
                    android:paddingHorizontal="15dp"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etHoursAddPieceFragment"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:hint="Duration (Hours)"
                        android:inputType="number"
                        android:paddingHorizontal="15dp"
                        android:textSize="15sp" />

                    <Spinner
                        android:id="@+id/etSizeAddPieceFragment"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_dropdown"
                        android:paddingHorizontal="10dp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etInformationAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/editbox_background_normal"
                    android:gravity="top"
                    android:hint="Describe your masterpiece..."
                    android:minHeight="100dp"
                    android:padding="15dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etPriceAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Price (USD $)"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="15dp"
                    android:textColor="#5B4242"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="20dp"/>

                <!-- قسم الصورة المطور والمدمج داخل الصندوق -->
                <TextView
                    android:id="@+id/tvImageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Masterpiece Image"
                    android:textColor="#8E7C7C"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="25dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#F0EBE8">

                    <ImageView
                        android:id="@+id/imgPieceItem"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:srcCompat="@android:drawable/ic_menu_camera"
                        app:tint="#5B4242" />
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btAddPieceFragment"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#5B4242"
                    android:text="PUBLISH ARTWORK"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="15dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>